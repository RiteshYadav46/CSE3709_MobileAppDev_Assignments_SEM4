<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#F0F2F5">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Sensor Dashboard"
        android:textSize="26sp"
        android:textStyle="bold"
        android:layout_gravity="center"
        android:layout_marginBottom="30dp"
        android:textColor="#333"/>

    <TextView android:text="Accelerometer (X, Y, Z):" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    <TextView android:id="@+id/txtAccel" android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="Waiting for data..." android:padding="10dp" android:background="#FFF" android:layout_marginBottom="20dp"/>

    <TextView android:text="Light Sensor (Lux):" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    <TextView android:id="@+id/txtLight" android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="Waiting for data..." android:padding="10dp" android:background="#FFF" android:layout_marginBottom="20dp"/>

    <TextView android:text="Proximity Sensor:" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    <TextView android:id="@+id/txtProximity" android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="Waiting for data..." android:padding="10dp" android:background="#FFF" android:layout_marginBottom="20dp"/>

</LinearLayout>